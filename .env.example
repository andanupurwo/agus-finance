# ============================================
# FIREBASE CONFIGURATION - Production
# ============================================
VITE_FIREBASE_API_KEY_PROD=your_prod_api_key
VITE_FIREBASE_AUTH_DOMAIN_PROD=agus-finance.firebaseapp.com
VITE_FIREBASE_PROJECT_ID_PROD=agus-finance
VITE_FIREBASE_STORAGE_BUCKET_PROD=agus-finance.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID_PROD=342544135388
VITE_FIREBASE_APP_ID_PROD=1:342544135388:web:5976177269c17e7ea9f019

# ============================================
# FIREBASE CONFIGURATION - Development
# ============================================
VITE_FIREBASE_API_KEY_DEV=your_dev_api_key
VITE_FIREBASE_AUTH_DOMAIN_DEV=dev-agus-finance.firebaseapp.com
VITE_FIREBASE_PROJECT_ID_DEV=dev-agus-finance
VITE_FIREBASE_STORAGE_BUCKET_DEV=dev-agus-finance.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID_DEV=your_dev_sender_id
VITE_FIREBASE_APP_ID_DEV=your_dev_app_id

# ============================================
# ENVIRONMENT
# ============================================
VITE_ENVIRONMENT=dev
# Ubah ke 'prod' untuk production!

# ============================================
# MAGIC CODE HASHES (SHA-256)
# Jangan pernah hardcode magic codes!
# ============================================
# VITE_MAGIC_CODE_PURWO=<sha256_hash>
# VITE_MAGIC_CODE_ASHRI=<sha256_hash>
# VITE_MAGIC_CODE_DEMO=<sha256_hash>

VITE_MAGIC_CODES_ENABLED=true

# ============================================
# DEV PIN & SECURITY
# ============================================
# HANYA UNTUK DEVELOPMENT - Jangan di production!
VITE_DEV_PIN=<hash_dari_0000>

# Session timeout (menit)
VITE_SESSION_TIMEOUT_MINUTES=30
VITE_SESSION_WARNING_MINUTES=5

# Rate limiting
VITE_LOGIN_MAX_ATTEMPTS=5
VITE_LOGIN_ATTEMPT_WINDOW_MINUTES=15

# ============================================
# DEBUG & LOGGING
# ============================================
VITE_DEBUG_MODE=true
VITE_LOG_SECURITY=true
